{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "target": "es2022",
    "sourceMap": true,
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "typeRoots": ["node_modules/@types", "src/types"],
    "composite": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/database" },
    { "path": "../../packages/markets" }
  ]
}
